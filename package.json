{
  "name": "eforge-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eforge-build/eforge.git"
  },
  "homepage": "https://eforge.build",
  "scripts": {
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @eforge-build/monitor-ui build",
    "restart-daemon": "eforge daemon stop && eforge daemon start",
    "build-and-restart": "pnpm build && pnpm restart-daemon",
    "dev:monitor": "pnpm --filter @eforge-build/monitor-ui dev",
    "test": "node scripts/check-skill-parity.mjs && vitest run",
    "test:watch": "vitest",
    "type-check": "pnpm -r type-check",
    "release": "node scripts/bump-version.mjs",
    "publish-all": "node scripts/publish-all.mjs",
    "docs:check-parity": "node scripts/check-skill-parity.mjs",
    "docs:generate": "pnpm --filter @eforge-build/docs-gen build && node packages/docs-gen/dist/cli.js generate --all",
    "docs:check": "pnpm --filter @eforge-build/docs-gen build && node packages/docs-gen/dist/cli.js check",
    "docs:dev": "pnpm docs:generate && pnpm --filter @eforge-build/web dev",
    "docs:build": "pnpm docs:generate && pnpm --filter @eforge-build/web build"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eforge-build/client": "workspace:*",
    "@eforge-build/web": "workspace:*",
    "@eforge-build/docs-gen": "workspace:*",
    "@eforge-build/engine": "workspace:*",
    "@eforge-build/monitor": "workspace:*",
    "@eforge-build/monitor-ui": "workspace:*",
    "@eforge-build/scopes": "workspace:*",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.7.0",
    "commander": "^14.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
