{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@eforge-build/engine/*": ["./packages/engine/src/*"],
      "@eforge-build/monitor/*": ["./packages/monitor/src/*"],
      "@eforge-build/monitor-ui/*": ["./packages/monitor-ui/src/*"],
      "@eforge-build/eforge/cli": ["./packages/eforge/src/cli/index.ts"],
      "@eforge-build/eforge/*": ["./packages/eforge/src/*"],
      "@eforge-build/client/*": ["./packages/client/src/*"],
      "@eforge-build/scopes/*": ["./packages/scopes/src/*"],
      "@eforge-build/input": ["./packages/input/src/index.ts"],
      "@eforge-build/input/*": ["./packages/input/src/*"],
      "@eforge-build/docs-gen/*": ["./packages/docs-gen/src/*"]
    }
  }
}
