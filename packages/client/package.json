  },
  "homepage": "https://eforge.build",
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "author": "Schaake Solutions LLC"
